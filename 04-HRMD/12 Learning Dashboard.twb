      <aliases enabled='yes' />
      <column caption='Training completion rate' datatype='real' name='[Calculation_2110006831209406464]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Training Completion Status] = &quot;Completed&quot; THEN 1 ELSE 0 END) &#10;/ &#10;COUNT([Training Completion Status]) * 100' />
      </column>
      <column caption='Training Effectiveness' datatype='real' name='[Calculation_2110006831211573249]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='( [Post-training Performance Score] - [Pre-training Performance Score] )&#10;/&#10;[Pre-training Performance Score]&#10;* 100' />
      </column>
      <column caption='Learningdata' datatype='table' name='[__tableau_internal_object_id__].[Learningdata_8F615747CC7844F6AB877C0BCB14E98D]' role='measure' type='quantitative' />
